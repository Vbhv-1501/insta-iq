# ── InstaIQ Backend Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values before running.

# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME=InstaIQ API
VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ── Supabase (free PostgreSQL) ───────────────────────────────────────────────
# Get these from https://supabase.com → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# Supabase PostgreSQL direct connection string (for SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ── Upstash Redis (free serverless Redis) ───────────────────────────────────
# Get this from https://console.upstash.com → Redis → Connect → .env
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Optional: Use Clerk instead of custom JWT
# CLERK_SECRET_KEY=sk_live_...

# ── OpenAI (for AI summaries) ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Scraper ──────────────────────────────────────────────────────────────────
# Optional: comma-separated proxy URLs for rotation
# PROXY_LIST=http://user:pass@proxy1.example.com:8080,http://user:pass@proxy2.example.com:8080
PROXY_LIST=
SCRAPE_DELAY_MS=1200
MAX_FOLLOWERS_FREE=5000
MAX_FOLLOWERS_PRO=500000

# ── Rate Limits ──────────────────────────────────────────────────────────────
FREE_ANALYSES_PER_DAY=3
PRO_ANALYSES_PER_DAY=9999

# ── CORS ─────────────────────────────────────────────────────────────────────
# Add your Vercel frontend URL here
ALLOWED_ORIGINS=["http://localhost:3000","https://instaiq.vercel.app"]

# ── Cloudinary (media storage) ───────────────────────────────────────────────
# Get this from https://cloudinary.com → Dashboard
CLOUDINARY_URL=cloudinary://YOUR_API_KEY:YOUR_API_SECRET@YOUR_CLOUD_NAME

# ── Monitoring ───────────────────────────────────────────────────────────────
# Optional: https://sentry.io → New Project → DSN
SENTRY_DSN=
